{
  "appName": "personal-portofolio",
  "projectName": "jakarta-project",
  
  "nexusGroup": "jpangalinan-poc",
  "nexusProject": "jakarta-project",
  "nexusRepository": "jp-snapshot",

  "build": {
    "enabled": true,
    "type": "nextjs",
    "builderImage": "node:20-alpine",
    "commands": {
      "install": "npm config set registry https://registry.npmjs.org && npm ci --include=dev",
      "build": "npm run build"
    }
  },

  "packaging": {
    "enabled": true,
    "outputName": "personal-portofolio",
    "format": "tar.gz",
    "axwayCompatible": true,
    "outputPath": "artifacts",
    "tempPath": ".packaging-temp",
    "excludePatterns": [
      "pipeline.json",
      ".git/**"
    ],
    "includePatterns": [
      ".",
      ".next/**"
    ]
  },
  "sonarScanner": {
    "enabled": true,
    "projectKey": "personal-portofolio",
    "projectName": "jakarta-project",
    "sources": ".",
    "exclusions": "**/node_modules/**,**/dist/**,**/coverage/**,**/*.test.ts,**/*.spec.ts",
    "waitForQualityGate": true,
    "mainBranches": [
      "main",
      "master",
      "develop"
    ]
  },
  "DEV": {
    "appServers": [
      {
        "server": "43.134.25.20",
        "serverCredential": "cred_super_secret",
        "deployPath": "/home/ubuntu/personal-portofolio",
       "execCommand": "cd /home/ubuntu/personal-portofolio && pm2 delete personal-portfolio || true && pm2 start \"serve -s out -l 80\" --name personal-portfolio"
      }
    ],
    "enabled": "true"
  },
  "PROD": {
    "appServers": [
      {
        "server": "43.134.25.20",
        "serverCredential": "cred_super_secret",
        "deployPath": "/home/ubuntu/personal-portofolio",
        "execCommand": "npm start"
      },
      {
        "server": "43.134.25.20",
        "serverCredential": "cred_super_secret",
        "deployPath": "/home/ubuntu/personal-portofolio",
        "execCommand": "npm start"
      }
    ],
    "enabled": "true"
  }
}
